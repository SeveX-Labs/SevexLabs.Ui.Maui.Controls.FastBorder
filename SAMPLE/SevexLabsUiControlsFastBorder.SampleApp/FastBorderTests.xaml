<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="SevexLabsUiControlsFastBorder.SampleApp.FastBorderTests"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SevexLabs.Ui.Maui.Controls.FastBorder;assembly=SevexLabs.Ui.Maui.Controls.FastBorder"
    BackgroundColor="#FFFFFF"
    Title="FastBorder Tests">

    <ScrollView>
        <VerticalStackLayout
            Padding="16"
            Spacing="20">


            <ContentView HorizontalOptions="Fill" VerticalOptions="Start">
                <ContentView.Padding>
                    <OnIdiom x:TypeArguments="Thickness">
                        <OnIdiom.Default>40, 10, 40, 10</OnIdiom.Default>
                        <OnIdiom.Phone>20, 10, 20, 10</OnIdiom.Phone>
                        <OnIdiom.Tablet>40, 10, 40, 10</OnIdiom.Tablet>
                    </OnIdiom>
                </ContentView.Padding>

                <controls:FastBorder HorizontalOptions="Fill" VerticalOptions="Start"
                                     BackgroundColor="#F3F4F6"
                                     CornerRadius="18"
                                     BorderThickness="0">

                    <controls:FastBorder.Shadow>
                        <Shadow Offset="0, 2"
                                Radius="8"
                                Brush="{StaticResource Gray900Brush}" />
                    </controls:FastBorder.Shadow>

                    <Grid HorizontalOptions="Fill" ColumnSpacing="10" RowSpacing="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="10"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="10"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="8"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <BoxView Grid.Row="0" Grid.RowSpan="5" Grid.Column="0"
                                 BackgroundColor="#CBD5E1"
                                 WidthRequest="112"
                                 HeightRequest="115" />

                        <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                               Text="Exercise title"
                               VerticalOptions="Start" VerticalTextAlignment="Start"
                               MaxLines="2" LineBreakMode="TailTruncation">
                        </Label>


                        <Label Grid.Row="3" Grid.Column="1" Text="05:00"
                               VerticalOptions="Start">
                        </Label>

                    </Grid>

                </controls:FastBorder>
            </ContentView>


            <controls:FastBorder BackgroundColor="LightBlue"
                                 Margin="0"
                                 BorderThickness="0" BorderColor="Transparent" Padding="20"
                                 HorizontalOptions="Start" VerticalOptions="Start">
                <BoxView
                    WidthRequest="24"
                    HeightRequest="24"
                    BackgroundColor="LightGreen"
                    HorizontalOptions="End"
                    VerticalOptions="End" />

            </controls:FastBorder>

            <!--
            <Border
                HeightRequest="120"
                BackgroundColor="#2D5AFF"
                BorderColor="Red"
                BorderThickness="2"
                HorizontalOptions="Fill"
                VerticalOptions="Start">
                <Label
                    HorizontalOptions="End"
                    BackgroundColor="Yellow"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="HERE"
                    TextColor="Black" />
            </Border>
            -->

            <Border
                x:Name="MauiBorderReference"
                HeightRequest="120"
                BackgroundColor="LightGray"
                Stroke="Red"
                StrokeThickness="2"
                StrokeShape="RoundRectangle 50"
                HorizontalOptions="Fill"
                VerticalOptions="Start"
                Margin="0">
                <Border.Shadow>
                    <Shadow
                        Brush="Blue"
                        Offset="2,2"
                        Opacity="0.70"
                        Radius="20" />
                </Border.Shadow>

                <Label
                    HorizontalOptions="End"
                    BackgroundColor="Yellow"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="BORDER"
                    TextColor="Black" />
            </Border>

            <controls:FastBorder
                HeightRequest="120"
                BackgroundColor="Transparent"
                BorderColor="Red"
                BorderThickness="2"
                CornerRadius="50"
                HorizontalOptions="Fill"
                VerticalOptions="Start"
                Margin="0">
                <controls:FastBorder.Shadow>
                    <Shadow
                        Brush="Blue"
                        Offset="2,2"
                        Opacity="0.70"
                        Radius="20" />
                </controls:FastBorder.Shadow>

                <Label
                    HorizontalOptions="End"
                    BackgroundColor="Yellow"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="FAST BORDER"
                    TextColor="Black" />
            </controls:FastBorder>

            <controls:FastBorder
                HeightRequest="120"
                BackgroundColor="Transparent"
                BorderColor="Red"
                BorderThickness="2"
                HorizontalOptions="Fill"
                VerticalOptions="Start">
                <controls:FastBorder.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="8,8"
                        Opacity="0.70"
                        Radius="18" />
                </controls:FastBorder.Shadow>

                <Label
                    HorizontalOptions="End"
                    BackgroundColor="Yellow"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="HERE"
                    TextColor="Black" />
            </controls:FastBorder>

            <Border
                HeightRequest="120"
                BackgroundColor="Transparent"
                Stroke="Red"
                StrokeThickness="2"
                Background="White"
                HorizontalOptions="Start"
                VerticalOptions="Start">
                <controls:FastBorder.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="8,8"
                        Opacity="0.70"
                        Radius="18" />
                </controls:FastBorder.Shadow>

                <Label
                    HorizontalOptions="End"
                    BackgroundColor="Yellow"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="BORDER_MAUI"
                    TextColor="Black" />
            </Border>

            <controls:FastBorder
                HeightRequest="120"
                BackgroundColor="Transparent"
                BorderColor="Red"
                BorderThickness="2"
                HorizontalOptions="Start"
                VerticalOptions="Start">
                <controls:FastBorder.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="8,8"
                        Opacity="0.70"
                        Radius="18" />
                </controls:FastBorder.Shadow>

                <Label
                    HorizontalOptions="End"
                    BackgroundColor="Yellow"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="FAST_BORDER"
                    TextColor="Black" />
            </controls:FastBorder>

            <controls:FastBorder
                HeightRequest="120"
                BackgroundColor="Transparent"
                BorderColor="Red"
                BorderThickness="2"
                HorizontalOptions="Center"
                VerticalOptions="Start">
                <controls:FastBorder.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="8,8"
                        Opacity="0.70"
                        Radius="18" />
                </controls:FastBorder.Shadow>

                <Label
                    HorizontalOptions="End"
                    BackgroundColor="Yellow"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="HERE"
                    TextColor="Black" />
            </controls:FastBorder>

            <controls:FastBorder
                HeightRequest="120"
                BackgroundColor="Transparent"
                BorderColor="Red"
                BorderThickness="2"
                HorizontalOptions="End"
                VerticalOptions="Start">
                <controls:FastBorder.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="8,8"
                        Opacity="0.70"
                        Radius="18" />
                </controls:FastBorder.Shadow>

                <Label
                    HorizontalOptions="End"
                    BackgroundColor="Yellow"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="HERE"
                    TextColor="Black" />
            </controls:FastBorder>

            <HorizontalStackLayout HorizontalOptions="Fill" HeightRequest="300" BackgroundColor="LightCoral">
                <controls:FastBorder
                    HeightRequest="70"
                    BackgroundColor="#2D5AFF"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="16"
                    HorizontalOptions="Start"
                    VerticalOptions="Start">
                </controls:FastBorder>
                <controls:FastBorder
                    HeightRequest="70"
                    BackgroundColor="#2D5AFF"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="16"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                </controls:FastBorder>
                <controls:FastBorder
                    HeightRequest="70"
                    BackgroundColor="#2D5AFF"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="16"
                    HorizontalOptions="End"
                    VerticalOptions="End">
                </controls:FastBorder>
            </HorizontalStackLayout>

            <HorizontalStackLayout HorizontalOptions="Fill" HeightRequest="300" BackgroundColor="LightGray">
                <Border
                    HeightRequest="70"
                    BackgroundColor="#2D5AFF"
                    Stroke="Red"
                    StrokeThickness="2"
                    Padding="16"
                    HorizontalOptions="Start"
                    VerticalOptions="Start">
                </Border>
                <Border
                    HeightRequest="70"
                    BackgroundColor="#2D5AFF"
                    Stroke="Red"
                    StrokeThickness="2"
                    Padding="16"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                </Border>
                <Border
                    HeightRequest="70"
                    BackgroundColor="#2D5AFF"
                    Stroke="Red"
                    StrokeThickness="2"
                    Padding="16"
                    HorizontalOptions="End"
                    VerticalOptions="End">
                </Border>
            </HorizontalStackLayout>

            <!-- Header -->
            <Label
                FontAttributes="Bold"
                FontSize="26"
                Text="FastBorder Tests"
                TextColor="Black" />

            <Label
                FontSize="14"
                Text="Pagina di test per verificare layout, stroke, corner radius, background, shadow, padding, alignment e contenuto."
                TextColor="#D0D0D0" />

            <!-- ===================================================== -->
            <!-- FULL WIDTH / HEIGHT-LIKE -->
            <!-- ===================================================== -->

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="A tutto schermo / full width"
                TextColor="Black" />

            <!-- Full width - content left -->
            <controls:FastBorder
                HeightRequest="120"
                BackgroundColor="#2D5AFF"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                HorizontalOptions="Fill"
                VerticalOptions="Start">
                <Label
                    HorizontalOptions="Start"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Full width - content left"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Full width - content center -->
            <controls:FastBorder
                HeightRequest="120"
                BackgroundColor="#00A86B"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                HorizontalOptions="Fill"
                VerticalOptions="Start">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Full width - content center"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Full width - content right -->
            <controls:FastBorder
                HeightRequest="120"
                BackgroundColor="#C75C00"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                HorizontalOptions="Fill"
                VerticalOptions="Start">
                <Label
                    HorizontalOptions="End"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Full width - content right"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- ===================================================== -->
            <!-- WIDTH CONTENT-BASED -->
            <!-- ===================================================== -->

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Shrink / content-based width"
                TextColor="Black" />

            <HorizontalStackLayout Spacing="12">
                <controls:FastBorder
                    BackgroundColor="#444444"
                    BorderColor="Lime"
                    BorderThickness="2"
                    Padding="16,10"
                    HorizontalOptions="Start">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="Sinistra"
                        TextColor="Black" />
                </controls:FastBorder>

                <controls:FastBorder
                    BackgroundColor="#444444"
                    BorderColor="Yellow"
                    BorderThickness="2"
                    Padding="16,10"
                    HorizontalOptions="CenterAndExpand">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="Centro"
                        TextColor="Black" />
                </controls:FastBorder>

                <controls:FastBorder
                    BackgroundColor="#444444"
                    BorderColor="Orange"
                    BorderThickness="2"
                    Padding="16,10"
                    HorizontalOptions="End">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="Destra"
                        TextColor="Black" />
                </controls:FastBorder>
            </HorizontalStackLayout>

            <!-- ===================================================== -->
            <!-- SHADOW ON / OFF -->
            <!-- ===================================================== -->

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Con e senza shadow"
                TextColor="Black" />

            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="16">

                <controls:FastBorder
                    Grid.Column="0"
                    BackgroundColor="#303030"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="16"
                    CornerRadius="16">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="No Shadow"
                        TextColor="Black" />
                </controls:FastBorder>

                <controls:FastBorder
                    Grid.Column="1"
                    BackgroundColor="#303030"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="16"
                    CornerRadius="16">
                    <controls:FastBorder.Shadow>
                        <Shadow
                            Brush="Black"
                            Offset="8,8"
                            Opacity="0.70"
                            Radius="18" />
                    </controls:FastBorder.Shadow>
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="With Shadow"
                        TextColor="Black" />
                </controls:FastBorder>
            </Grid>

            <!-- ===================================================== -->
            <!-- BORDER ON / OFF -->
            <!-- ===================================================== -->

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Con e senza border"
                TextColor="Black" />

            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="16">

                <controls:FastBorder
                    Grid.Column="0"
                    BackgroundColor="#5A2D82"
                    BorderThickness="0"
                    Padding="16"
                    CornerRadius="14">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="No Border"
                        TextColor="Black" />
                </controls:FastBorder>

                <controls:FastBorder
                    Grid.Column="1"
                    BackgroundColor="#5A2D82"
                    BorderColor="Red"
                    BorderThickness="3"
                    Padding="16"
                    CornerRadius="14">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="With Border"
                        TextColor="Black" />
                </controls:FastBorder>
            </Grid>

            <!-- ===================================================== -->
            <!-- CORNER RADIUS ON / OFF -->
            <!-- ===================================================== -->

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Con e senza corner radius"
                TextColor="Black" />

            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="16">

                <controls:FastBorder
                    Grid.Column="0"
                    BackgroundColor="#0E7490"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="16">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="CornerRadius 0"
                        TextColor="Black" />
                </controls:FastBorder>

                <controls:FastBorder
                    Grid.Column="1"
                    BackgroundColor="#0E7490"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="16"
                    CornerRadius="22">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="CornerRadius 22"
                        TextColor="Black" />
                </controls:FastBorder>
            </Grid>

            <!-- ===================================================== -->
            <!-- BACKGROUND ON / OFF -->
            <!-- ===================================================== -->

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Con e senza background color"
                TextColor="Black" />

            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="16">

                <controls:FastBorder
                    Grid.Column="0"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="16"
                    CornerRadius="18">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="No Background"
                        TextColor="Black" />
                </controls:FastBorder>

                <controls:FastBorder
                    Grid.Column="1"
                    BackgroundColor="#AA1D5D"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="16"
                    CornerRadius="18">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="With Background"
                        TextColor="Black" />
                </controls:FastBorder>
            </Grid>

            <!-- ===================================================== -->
            <!-- PER-CORNER RADIUS -->
            <!-- ===================================================== -->

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="CornerRadius per angolo"
                TextColor="Black" />

            <Label
                FontSize="13"
                Text="Test per verificare CornerRadius uniforme e differenziato per TopLeft, TopRight, BottomLeft, BottomRight."
                TextColor="#707070" />

            <!-- Uniforme: deve comportarsi come prima -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#1F6F78"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="30"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Uniforme: 30"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Solo TopLeft -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#2D5AFF"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="40,0,0,0"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Solo TopLeft: 40,0,0,0"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Solo TopRight -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#00A86B"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="0,40,0,0"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Solo TopRight: 0,40,0,0"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Solo BottomLeft -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#C75C00"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="0,0,40,0"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Solo BottomLeft: 0,0,40,0"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Solo BottomRight -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#AA1D5D"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="0,0,0,40"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Solo BottomRight: 0,0,0,40"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Diagonale TopLeft + BottomRight -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#5A2D82"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="40,0,0,40"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Diagonale: 40,0,0,40"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Diagonale TopRight + BottomLeft -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#0E7490"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="0,40,40,0"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Diagonale: 0,40,40,0"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Angoli superiori arrotondati -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#374151"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="40,40,0,0"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Solo top: 40,40,0,0"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Angoli inferiori arrotondati -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#065F46"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="0,0,40,40"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Solo bottom: 0,0,40,40"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Valori tutti diversi -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#7C2D12"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="8,24,40,56"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Diversi: 8,24,40,56"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Raggio molto grande, utile per verificare clamp/normalizzazione -->
            <controls:FastBorder
                HeightRequest="90"
                BackgroundColor="#1F2937"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="80,80,80,80"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Grande: 80,80,80,80"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Background trasparente + corner radius differenziato -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="Transparent"
                BorderColor="#22D3EE"
                BorderThickness="3"
                Padding="16"
                CornerRadius="40,8,40,8"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Transparent: 40,8,40,8"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Shadow + corner radius differenziato -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#303030"
                BorderColor="Red"
                BorderThickness="2"
                Padding="16"
                CornerRadius="40,0,40,0"
                HorizontalOptions="Fill">
                <controls:FastBorder.Shadow>
                    <Shadow
                        Brush="Black"
                        Offset="8,8"
                        Opacity="0.70"
                        Radius="18" />
                </controls:FastBorder.Shadow>

                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Shadow: 40,0,40,0"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Border spesso + corner radius differenziato -->
            <controls:FastBorder
                HeightRequest="110"
                BackgroundColor="#2B2B2B"
                BorderColor="#8B5CF6"
                BorderThickness="8"
                Padding="16"
                CornerRadius="48,12,48,12"
                HorizontalOptions="Fill">
                <Label
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Border 8: 48,12,48,12"
                    TextColor="Black" />
            </controls:FastBorder>

            <!-- Contenuto colorato per verificare eventuale clipping -->
            <controls:FastBorder
                HeightRequest="130"
                BackgroundColor="#F3F4F6"
                BorderColor="Red"
                BorderThickness="2"
                Padding="0"
                CornerRadius="40,0,40,0"
                HorizontalOptions="Fill">
                <Grid BackgroundColor="LightGreen">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Content clipping test"
                        TextColor="Black" />
                </Grid>
            </controls:FastBorder>

            <!-- ===================================================== -->
            <!-- PADDING TEST -->
            <!-- ===================================================== -->

            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Padding test"
                TextColor="Black" />

            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="16">

                <controls:FastBorder
                    Grid.Column="0"
                    BackgroundColor="#374151"
                    BorderColor="Red"
                    BorderThickness="2"
                    Padding="4"
                    CornerRadius="14">
                    <Label
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontAttributes="Bold"
                        Text="Padding 4"
                        TextColor="Black" />
                </controls:FastBorder>

                <controls:FastBorder
                    Grid.Column="1"
                    BackgroundColor="#374151"
